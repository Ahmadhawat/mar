```python
from __future__ import annotations

import json
from pathlib import Path
from typing import Dict, List

from src.search_steps.impls.reranking.CrerankingABS import Reranking
from src.pipeline.context import Context
from src.search_steps.impls.vector_search.CVectorSearchV1 import (
    chunk_to_real_path,
    chunk_to_real_txt,
)
from src.search_steps.impls.reranking.reranker_client import RerankerClient


class CrossEncoderReranking(Reranking):
    name = "cross_encoder_rerank"

    def run(self, ctx: Context) -> None:
        log = ctx.log.getChild(self.name)

        cfg = ctx.cfg
        paths = cfg["paths"]
        hybrid_json_path = Path(paths["hybrid_results_path"])
        source_html_root = Path(paths["source_html_root"])
        source_txt_root = Path(paths["source_txt_root"])

        rerank_cfg: Dict[str, object] = cfg.get("rerank", {})
        alpha = float(rerank_cfg.get("alpha", 0.65))
        batch_size = int(rerank_cfg.get("batch_size", 32))
        ce_top_n = int(rerank_cfg.get("ce_top_n", 25))
        window_tokens = int(rerank_cfg.get("window_tokens", 180))
        max_windows_per_doc = rerank_cfg.get("max_windows_per_doc", 6)
        max_windows_per_doc = None if max_windows_per_doc in (None, 0) else int(max_windows_per_doc)
        top_k = int(rerank_cfg.get("top_k", 10))
        reranker_url = str(rerank_cfg.get("service_url", "http://127.0.0.1:8001"))

        query = (
            ctx.artifacts.get("corrected_query")
            or cfg.get("query", {}).get("text", "")
            or ""
        )
        if not query.strip():
            raise ValueError("cfg.query.text is required for cross-encoder rerank.")

        log.info(f"Using query: {query}")
        log.info(f"Loading results from: {hybrid_json_path}")

        with hybrid_json_path.open("r", encoding="utf-8") as f:
            data = json.load(f)

        raw_results: List[Dict] = list(data.get("results", []))
        if not raw_results:
            log.warning("No results to rerank; exiting.")
            return

        raw_results.sort(key=lambda r: float(r.get("rrf_score", 0.0)), reverse=True)
        raw_results = raw_results[:max(1, ce_top_n)]

        candidates = []
        for r in raw_results:
            chunk_path = Path(r.get("chunkpath", ""))
            if not chunk_path.exists():
                log.warning(f"Chunk file not found: {chunk_path}")
                continue

            text = chunk_path.read_text(encoding="utf-8", errors="ignore").strip()

            candidates.append(
                {
                    "chunkpath": str(chunk_path),
                    "chunk_name": str(r.get("chunk_name", "")),
                    "text": text,
                    "rrf_score": float(r.get("rrf_score", 0.0)),
                    "file_txt": chunk_to_real_txt(str(r.get("chunk_name", "")), source_txt_root or None),
                    "file_path_html": chunk_to_real_path(str(r.get("chunk_name", "")), source_html_root or None),
                }
            )

        if not candidates:
            log.warning("No readable chunks; exiting.")
            return

        client = RerankerClient(base_url=reranker_url)
        result = client.rerank(
            query=query,
            candidates=candidates,
            alpha=alpha,
            batch_size=batch_size,
            window_tokens=window_tokens,
            max_windows_per_doc=max_windows_per_doc,
            top_k=top_k,
        )

        ranked_results = result["results"]

        for rank, item in enumerate(ranked_results[:max(10, top_k)], 1):
            log.info(
                f"Rank {rank}: {item['chunkpath']} "
                f"(CE: {item['ce_score']:.6f}, blended: {item['blended_score']:.6f})"
            )

        out = {
            "query": result["query"],
            "model": result["model"],
            "alpha": result["alpha"],
            "results": ranked_results,
        }

        sorted_chunkpaths = [r["chunkpath"] for r in ranked_results]
        sorted_file_htmls = [r["file_path_html"] for r in ranked_results]

        ctx.artifacts["rerank_files_html"] = sorted_file_htmls
        ctx.artifacts["rerank_chunks_paths"] = sorted_chunkpaths

        out_path = hybrid_json_path.with_name("reranked_results.json")
        out_path.write_text(json.dumps(out, ensure_ascii=False, indent=2), encoding="utf-8")
        log.info(f"Wrote: {out_path}")
