from __future__ import annotations

import os
import re
import threading
from contextlib import contextmanager
from typing import Dict, Iterable, List, Optional

from fastapi import FastAPI, HTTPException
from pydantic import BaseModel, Field, field_validator
from sentence_transformers import CrossEncoder

try:
    import torch
    INFERENCE_CTX = torch.inference_mode
except Exception:
    @contextmanager
    def INFERENCE_CTX():
        yield


# ---------------- deployment / safety limits ----------------

MAX_CANDIDATES = int(os.getenv("RERANK_MAX_CANDIDATES", "50"))
MAX_BATCH_SIZE = int(os.getenv("RERANK_MAX_BATCH_SIZE", "64"))
MAX_TOP_K = int(os.getenv("RERANK_MAX_TOP_K", "20"))
MAX_TEXT_CHARS = int(os.getenv("RERANK_MAX_TEXT_CHARS", "20000"))
MAX_WINDOW_TOKENS = int(os.getenv("RERANK_MAX_WINDOW_TOKENS", "512"))
MAX_WINDOWS_PER_DOC = int(os.getenv("RERANK_MAX_WINDOWS_PER_DOC", "20"))

MODEL_NAME = os.getenv("RERANK_MODEL_NAME", "BAAI/bge-reranker-v2-m3")
DEVICE = os.getenv("RERANK_DEVICE", "cpu")

PREDICT_LOCK = threading.Lock()

app = FastAPI(title="CrossEncoder Reranker Service")
model: Optional[CrossEncoder] = None


# ---------------- helpers ----------------

def clean_text(text: str) -> str:
    """Fix PDF hyphenation and collapse ugly newlines while keeping paragraphs."""
    t = text.replace("-\n", "")
    t = t.replace("\r", "\n")
    t = "\n".join(line.strip() for line in t.splitlines())
    t = "\n\n".join(p for p in t.split("\n\n") if p.strip())
    return t


def make_windows(text: str, approx_tokens: int, max_windows: Optional[int] = None) -> List[str]:
    """
    Split into sentence-ish windows of about approx_tokens words
    with one-sentence overlap.
    """
    sents = re.split(r"(?<=[.!?:;])\s+", text)
    blocks: List[str] = []
    cur: List[str] = []
    wc = 0

    for s in sents:
        if not s.strip():
            continue

        cur.append(s)
        wc += len(s.split())

        if wc >= approx_tokens:
            blocks.append(" ".join(cur))
            cur = cur[-1:]
            wc = len(cur[-1].split())

            if max_windows is not None and len(blocks) >= max_windows:
                break

    if cur and (max_windows is None or len(blocks) < max_windows):
        blocks.append(" ".join(cur))

    return blocks or [text]


def de_query_variants(q: str) -> List[str]:
    """Tiny German compound expansion; aggregate by MAX to preserve precision."""
    variants = [q]
    ql = q.lower()
    extra: List[str] = []

    if "querprofil" in ql:
        extra += [
            "Querprofillinie",
            "Querprofillinien",
            "Querschnittsprofil",
            "Querprofil-Linie",
        ]
    if "station" in ql or "achsstation" in ql:
        extra += ["Achsstation", "Stationierung", "Stationen"]
    if "plot" in ql or "plotten" in ql:
        extra += ["zeichnen", "darstellen", "plot", "erstellen"]

    if extra:
        variants.append(q + " (" + ", ".join(extra[:6]) + ")")

    return variants


def norm(values: Iterable[float]) -> List[float]:
    vals = [float(x) for x in values]
    if not vals:
        return vals
    mn, mx = min(vals), max(vals)
    rng = mx - mn
    return [(x - mn) / (rng + 1e-9) for x in vals]


def score_candidate(
    *,
    model: CrossEncoder,
    qvars: List[str],
    text: str,
    batch_size: int,
    window_tokens: int,
    max_windows_per_doc: Optional[int],
) -> float:
    """
    Score one candidate by taking MAX over:
      query variants x text windows

    Scoring is chunked to avoid building huge `pairs` lists.
    """
    windows = make_windows(
        clean_text(text),
        approx_tokens=window_tokens,
        max_windows=max_windows_per_doc,
    )

    best_score = float("-inf")
    buffer: List[tuple[str, str]] = []

    for qv in qvars:
        for w in windows:
            buffer.append((qv, w))
            if len(buffer) >= batch_size:
                scores = model.predict(
                    buffer,
                    batch_size=len(buffer),
                    show_progress_bar=False,
                )
                best_score = max(best_score, float(max(scores)))
                buffer.clear()

    if buffer:
        scores = model.predict(
            buffer,
            batch_size=len(buffer),
            show_progress_bar=False,
        )
        best_score = max(best_score, float(max(scores)))

    return best_score


# ---------------- API models ----------------

class CandidateIn(BaseModel):
    chunkpath: str = Field(default="")
    chunk_name: str = Field(default="")
    text: str = Field(min_length=1)
    rrf_score: float = Field(default=0.0)
    file_txt: str = Field(default="")
    file_path_html: str = Field(default="")

    @field_validator("text")
    @classmethod
    def validate_text(cls, v: str) -> str:
        v = v.strip()
        if not v:
            raise ValueError("Candidate text must not be empty.")
        if len(v) > MAX_TEXT_CHARS:
            v = v[:MAX_TEXT_CHARS]
        return v


class RerankRequest(BaseModel):
    query: str = Field(min_length=1)
    candidates: List[CandidateIn] = Field(min_length=1, max_length=MAX_CANDIDATES)
    alpha: float = Field(default=0.65, ge=0.0, le=1.0)
    batch_size: int = Field(default=32, ge=1, le=MAX_BATCH_SIZE)
    window_tokens: int = Field(default=180, ge=20, le=MAX_WINDOW_TOKENS)
    max_windows_per_doc: Optional[int] = Field(default=6, ge=1, le=MAX_WINDOWS_PER_DOC)
    top_k: int = Field(default=10, ge=1, le=MAX_TOP_K)

    @field_validator("query")
    @classmethod
    def validate_query(cls, v: str) -> str:
        v = v.strip()
        if not v:
            raise ValueError("Query must not be empty.")
        return v


class RankedResult(BaseModel):
    chunkpath: str
    chunk_name: str
    file_txt: str
    file_path_html: str
    ce_score: float
    blended_score: float
    rrf_score: float


class RerankResponse(BaseModel):
    query: str
    model: str
    alpha: float
    results: List[RankedResult]


# ---------------- lifecycle ----------------

@app.on_event("startup")
def startup_event() -> None:
    global model
    model = CrossEncoder(MODEL_NAME, max_length=512, device=DEVICE)
    print(f"[reranker] loaded model={MODEL_NAME} device={DEVICE}")


@app.get("/health")
def health() -> Dict[str, str]:
    return {
        "status": "ok" if model is not None else "not_ready",
        "model": MODEL_NAME,
        "device": DEVICE,
    }


# ---------------- main endpoint ----------------

@app.post("/rerank", response_model=RerankResponse)
def rerank(req: RerankRequest) -> RerankResponse:
    global model

    if model is None:
        raise HTTPException(status_code=500, detail="Model not loaded.")

    if len(req.candidates) > MAX_CANDIDATES:
        raise HTTPException(
            status_code=400,
            detail=f"Too many candidates. Max allowed is {MAX_CANDIDATES}.",
        )

    qvars = de_query_variants(req.query)
    retriever_scores = [c.rrf_score for c in req.candidates]
    ce_scores: List[float] = []

    # Serialize access to model.predict(...) for one-model / one-GPU stability.
    with PREDICT_LOCK:
        with INFERENCE_CTX():
            for cand in req.candidates:
                ce_score = score_candidate(
                    model=model,
                    qvars=qvars,
                    text=cand.text,
                    batch_size=req.batch_size,
                    window_tokens=req.window_tokens,
                    max_windows_per_doc=req.max_windows_per_doc,
                )
                ce_scores.append(ce_score)

    ce_n = norm(ce_scores)
    ret_n = norm(retriever_scores)
    blended = [
        req.alpha * c + (1.0 - req.alpha) * r
        for c, r in zip(ce_n, ret_n)
    ]

    order = sorted(range(len(req.candidates)), key=lambda i: blended[i], reverse=True)

    ranked = [
        RankedResult(
            chunkpath=req.candidates[i].chunkpath,
            chunk_name=req.candidates[i].chunk_name,
            file_txt=req.candidates[i].file_txt,
            file_path_html=req.candidates[i].file_path_html,
            ce_score=ce_scores[i],
            blended_score=blended[i],
            rrf_score=req.candidates[i].rrf_score,
        )
        for i in order[:req.top_k]
    ]

    return RerankResponse(
        query=req.query,
        model=MODEL_NAME,
        alpha=req.alpha,
        results=ranked,
    )
