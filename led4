def now_iso() -> str:
    return datetime.now().isoformat(timespec="seconds")


# --------------------------------------------------
# Load batch evaluation config
# --------------------------------------------------

def load_batch_eval_config(path: str = "config/config.ledger.yaml") -> Dict[str, Any]:
    with open(path, "r", encoding="utf-8") as f:
        cfg = yaml.safe_load(f)
    if "batch_eval" not in cfg:
        raise ValueError("config.ledger.yaml must contain 'batch_eval'")
    return cfg["batch_eval"]


