def load_input_dataframe(input_xlsx: Path, id_col: str, reference_col: str, question_col: str) -> pd.DataFrame:
    if not input_xlsx.exists():
        raise FileNotFoundError(f"Input file not found: {input_xlsx}")

    df = pd.read_excel(input_xlsx)

    required_cols = [id_col, reference_col, question_col]
    missing_cols = [col for col in required_cols if col not in df.columns]
    if missing_cols:
        raise ValueError(
            f"Missing required columns in {input_xlsx}: {missing_cols}. "
            f"Available columns: {list(df.columns)}"
        )

    mask = df[question_col].notna() & df[question_col].astype(str).str.strip().astype(bool)
    df = df[mask].copy()

    if df.empty:
        raise ValueError("No valid question rows found in Excel.")

    return df


