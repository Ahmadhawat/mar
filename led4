def create_run_record(conn: sqlite3.Connection, run_dir: Path, input_xlsx: Path) -> int:
    ts = now_iso()
    run_name = run_dir.name
    cur = conn.execute(
        """
        INSERT INTO runs (run_name, run_dir, input_xlsx, status, created_at, updated_at)
        VALUES (?, ?, ?, ?, ?, ?)
        """,
        (run_name, str(run_dir), str(input_xlsx), "created", ts, ts),
    )
    conn.commit()
    return cur.lastrowid


def get_run_by_dir(conn: sqlite3.Connection, run_dir: Path) -> Optional[sqlite3.Row]:
    cur = conn.execute(
        "SELECT * FROM runs WHERE run_dir = ?",
        (str(run_dir),),
    )
    return cur.fetchone()


def update_run_status(conn: sqlite3.Connection, run_id: int, status: str) -> None:
    conn.execute(
        """
        UPDATE runs
        SET status = ?, updated_at = ?
        WHERE id = ?
        """,
        (status, now_iso(), run_id),
    )
    conn.commit()


def create_or_get_config_run(
    conn: sqlite3.Connection,
    run_id: int,
    config_name: str,
    config_path: Path,
    config_snapshot_path: Path,
) -> int:
    ts = now_iso()
    conn.execute(
        """
        INSERT OR IGNORE INTO config_runs (
            run_id, config_name, config_path, config_snapshot_path, status, created_at, updated_at
        )
        VALUES (?, ?, ?, ?, ?, ?, ?)
        """,
        (
            run_id,
            config_name,
            str(config_path),
            str(config_snapshot_path),
            "created",
            ts,
            ts,
        ),
    )
    conn.commit()

    cur = conn.execute(
        """
        SELECT id
        FROM config_runs
        WHERE run_id = ? AND config_name = ?
        """,
        (run_id, config_name),
    )
    row = cur.fetchone()
    if row is None:
        raise RuntimeError(f"Could not create or retrieve config_run for {config_name}")
    return int(row["id"])


def get_config_runs_for_run(conn: sqlite3.Connection, run_id: int) -> List[sqlite3.Row]:
    cur = conn.execute(
        """
        SELECT *
        FROM config_runs
        WHERE run_id = ?
        ORDER BY config_name
        """,
        (run_id,),
    )
    return cur.fetchall()


def update_config_run_status(conn: sqlite3.Connection, config_run_id: int, status: str) -> None:
    conn.execute(
        """
        UPDATE config_runs
        SET status = ?, updated_at = ?
        WHERE id = ?
        """,
        (status, now_iso(), config_run_id),
    )
    conn.commit()


def register_tasks(
    conn: sqlite3.Connection,
    config_run_id: int,
    df: pd.DataFrame,
    id_col: str,
    reference_col: str,
    question_col: str,
) -> int:
    ts = now_iso()
    inserted_or_existing = 0

    for _, row in df.iterrows():
        source_id = row[id_col]
        reference = row[reference_col]
        question = row[question_col]

        if pd.isna(question):
            continue

        question = str(question).strip()
        if not question:
            continue

        reference = "" if pd.isna(reference) else str(reference).strip()

        if pd.isna(source_id):
            raise ValueError("Encountered empty source_id in Excel; id column must be present for all rows.")

        conn.execute(
            """
            INSERT OR IGNORE INTO tasks (
                config_run_id,
                source_id,
                reference,
                question,
                status,
                updated_at
            )
            VALUES (?, ?, ?, ?, 'pending', ?)
            """,
            (
                config_run_id,
                int(source_id),
                reference,
                question,
                ts,
            ),
        )
        inserted_or_existing += 1

    conn.commit()
    return inserted_or_existing


def reset_running_tasks_to_pending(conn: sqlite3.Connection) -> int:
    cur = conn.execute(
        """
        UPDATE tasks
        SET status = 'pending',
            updated_at = ?
        WHERE status = 'running'
        """,
        (now_iso(),),
    )
    conn.commit()
    return cur.rowcount


def fetch_next_task(
    conn: sqlite3.Connection,
    config_run_id: int,
    max_retries: int,
) -> Optional[sqlite3.Row]:
    cur = conn.execute(
        """
        SELECT *
        FROM tasks
        WHERE config_run_id = ?
          AND (
                status = 'pending'
                OR (status = 'error' AND attempt_count < ?)
              )
        ORDER BY source_id ASC, id ASC
        LIMIT 1
        """,
        (config_run_id, max_retries),
    )
    return cur.fetchone()


def mark_task_running(conn: sqlite3.Connection, task_id: int) -> None:
    ts = now_iso()
    conn.execute(
        """
        UPDATE tasks
        SET status = 'running',
            started_at = COALESCE(started_at, ?),
            updated_at = ?
        WHERE id = ?
        """,
        (ts, ts, task_id),
    )
    conn.commit()


def mark_task_done(
    conn: sqlite3.Connection,
    task_id: int,
    answer: Optional[str],
    raw_files: str,
    corrected_query: str,
) -> None:
    ts = now_iso()
    conn.execute(
        """
        UPDATE tasks
        SET status = 'done',
            answer = ?,
            raw_files = ?,
            corrected_query = ?,
            error_message = NULL,
            finished_at = ?,
            updated_at = ?
        WHERE id = ?
        """,
        (answer, raw_files, corrected_query, ts, ts, task_id),
    )
    conn.commit()


def mark_task_error(conn: sqlite3.Connection, task_id: int, error_message: str) -> None:
    ts = now_iso()
    conn.execute(
        """
        UPDATE tasks
        SET status = 'error',
            attempt_count = attempt_count + 1,
            error_message = ?,
            updated_at = ?
        WHERE id = ?
        """,
        (error_message[:4000], ts, task_id),
    )
    conn.commit()


def get_task_counts_for_config(conn: sqlite3.Connection, config_run_id: int) -> Dict[str, int]:
    cur = conn.execute(
        """
        SELECT status, COUNT(*) AS cnt
        FROM tasks
        WHERE config_run_id = ?
        GROUP BY status
        """,
        (config_run_id,),
    )
    counts = {"pending": 0, "running": 0, "done": 0, "error": 0}
    for row in cur.fetchall():
        counts[row["status"]] = int(row["cnt"])
    return counts


def get_retryable_error_count_for_config(conn: sqlite3.Connection, config_run_id: int, max_retries: int) -> int:
    cur = conn.execute(
        """
        SELECT COUNT(*) AS cnt
        FROM tasks
        WHERE config_run_id = ?
          AND status = 'error'
          AND attempt_count < ?
        """,
        (config_run_id, max_retries),
    )
    row = cur.fetchone()
    return int(row["cnt"] if row else 0)


def get_non_retryable_error_count_for_config(conn: sqlite3.Connection, config_run_id: int, max_retries: int) -> int:
    cur = conn.execute(
        """
        SELECT COUNT(*) AS cnt
        FROM tasks
        WHERE config_run_id = ?
          AND status = 'error'
          AND attempt_count >= ?
        """,
        (config_run_id, max_retries),
    )
    row = cur.fetchone()
    return int(row["cnt"] if row else 0)


def refresh_config_run_final_status(conn: sqlite3.Connection, config_run_id: int, max_retries: int) -> str:
    counts = get_task_counts_for_config(conn, config_run_id)
    permanent_errors = get_non_retryable_error_count_for_config(conn, config_run_id, max_retries)

    if counts["pending"] == 0 and counts["running"] == 0 and counts["error"] == 0:
        status = "completed"
    elif counts["pending"] == 0 and counts["running"] == 0 and permanent_errors > 0:
        status = "completed_with_errors"
    else:
        status = "running"

    update_config_run_status(conn, config_run_id, status)
    return status


def refresh_run_final_status(conn: sqlite3.Connection, run_id: int) -> str:
    cur = conn.execute(
        """
        SELECT status, COUNT(*) AS cnt
        FROM config_runs
        WHERE run_id = ?
        GROUP BY status
        """,
        (run_id,),
    )

    summary = {}
    for row in cur.fetchall():
        summary[row["status"]] = int(row["cnt"])

    if not summary:
        status = "failed"
    elif set(summary.keys()) == {"completed"}:
        status = "completed"
    elif "running" in summary or "created" in summary:
        status = "running"
    elif "completed_with_errors" in summary:
        status = "completed_with_errors"
    elif "failed" in summary:
        status = "failed"
    else:
        status = "completed_with_errors"

    update_run_status(conn, run_id, status)
    return status


