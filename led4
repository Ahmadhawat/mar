def save_config_snapshot(cfg_snapshot_path: Path, snapshot: Dict[str, Any]) -> None:
    cfg_snapshot_path.parent.mkdir(parents=True, exist_ok=True)
    with cfg_snapshot_path.open("w", encoding="utf-8") as f:
        yaml.safe_dump(snapshot, f, sort_keys=False, allow_unicode=True)


def create_new_run(
    conn: sqlite3.Connection,
    be_cfg: Dict[str, Any],
    run_dir: Path,
    df: pd.DataFrame,
    logs,
) -> int:
    input_xlsx = Path(be_cfg["input_xlsx"])
    id_col = be_cfg.get("id_col", "id")
    reference_col = be_cfg.get("reference_col", "reference")
    question_col = be_cfg.get("question_col", "frage")
    snapshot_paths = be_cfg.get("snapshot_paths", [])
    search_cfg_folder = Path(be_cfg["search_config_folder"])
    cfg_files = sorted(search_cfg_folder.glob("*.yaml"))
    cfg_snapshot_name = be_cfg["filenames"]["config_snapshot"]

    if not cfg_files:
        raise FileNotFoundError(
            f"No *.yaml files found in {search_cfg_folder}. "
            "Please provide at least one configuration file."
        )

    run_id = create_run_record(conn, run_dir, input_xlsx)
    update_run_status(conn, run_id, "running")

    logs.info(f"Created new run: {run_dir}")

    for cfg_path in cfg_files:
        cfg_name = cfg_path.stem
        search_cfg = load_config(cfg_path)

        config_dir = create_config_folder(run_dir, cfg_name)
        cfg_snapshot_path = config_dir / cfg_snapshot_name

        snapshot = build_config_snapshot(search_cfg, snapshot_paths)
        save_config_snapshot(cfg_snapshot_path, snapshot)

        config_run_id = create_or_get_config_run(
            conn=conn,
            run_id=run_id,
            config_name=cfg_name,
            config_path=cfg_path,
            config_snapshot_path=cfg_snapshot_path,
        )

        registered = register_tasks(
            conn=conn,
            config_run_id=config_run_id,
            df=df,
            id_col=id_col,
            reference_col=reference_col,
            question_col=question_col,
        )

        logs.info(f"[{cfg_name}] registered tasks: {registered}")

    refresh_run_final_status(conn, run_id)
    return run_id


def resume_existing_run(
    conn: sqlite3.Connection,
    run_dir: Path,
    logs,
) -> int:
    run_row = get_run_by_dir(conn, run_dir)
    if run_row is None:
        raise ValueError(f"No run found in database for run_dir={run_dir}")

    run_id = int(run_row["id"])
    reset_count = reset_running_tasks_to_pending(conn)
    if reset_count:
        logs.info(f"Reset {reset_count} stale running tasks to pending")

    update_run_status(conn, run_id, "running")

    config_rows = get_config_runs_for_run(conn, run_id)
    for cfg_row in config_rows:
        update_config_run_status(conn, int(cfg_row["id"]), "running")

    logs.info(f"Resuming run: {run_dir}")
    return run_id


# --------------------------------------------------
# Processing
# --------------------------------------------------

def process_config_run(
    conn: sqlite3.Connection,
    config_row: sqlite3.Row,
    max_retries: int,
    logs,
) -> None:
    config_run_id = int(config_row["id"])
    config_name = str(config_row["config_name"])
    config_path = Path(str(config_row["config_path"]))

    search_cfg = load_config(config_path)
    pipeline = make_pipeline(search_cfg["run"]["steps"])

    update_config_run_status(conn, config_run_id, "running")

    initial_counts = get_task_counts_for_config(conn, config_run_id)
    retryable = get_retryable_error_count_for_config(conn, config_run_id, max_retries)
    logs.info(
        f"[{config_name}] start: done={initial_counts['done']} "
        f"pending={initial_counts['pending']} error={initial_counts['error']} "
        f"retryable_errors={retryable}"
    )

    while True:
        task = fetch_next_task(conn, config_run_id, max_retries)
        if task is None:
            break

        task_id = int(task["id"])
        source_id = int(task["source_id"])
        question = str(task["question"])
        current_attempts = int(task["attempt_count"])

        mark_task_running(conn, task_id)
        logs.info(
            f"[{config_name}] processing source_id={source_id} "
            f"attempt={current_attempts + 1}/{max_retries} | {question}"
        )

        try:
            output: Outputs = run_query(question, pipeline, search_cfg, logs)

            answer = output.answer if output.answer is not None else ""
            raw_files = ", ".join(output.rank_html or [])
            corrected_query = output.corrected_query or ""

            mark_task_done(
                conn=conn,
                task_id=task_id,
                answer=answer,
                raw_files=raw_files,
                corrected_query=corrected_query,
            )

        except Exception as e:
            mark_task_error(conn, task_id, repr(e))
            logs.exception(f"[{config_name}] failed source_id={source_id}")

    final_status = refresh_config_run_final_status(conn, config_run_id, max_retries)
    final_counts = get_task_counts_for_config(conn, config_run_id)
    permanent_errors = get_non_retryable_error_count_for_config(conn, config_run_id, max_retries)

    logs.info(
        f"[{config_name}] finished with status={final_status} | "
        f"done={final_counts['done']} pending={final_counts['pending']} "
        f"running={final_counts['running']} error={final_counts['error']} "
        f"permanent_errors={permanent_errors}"
    )


