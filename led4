# Config snapshot helpers
# --------------------------------------------------

def extract_from_path(root: Dict[str, Any], path: str):
    parts = path.split(".")
    cur = root
    for p in parts:
        if isinstance(cur, dict) and p in cur:
            cur = cur[p]
        else:
            return None
    return cur


def insert_into_path(root: Dict[str, Any], path: str, value: Any):
    parts = path.split(".")
    cur = root
    for p in parts[:-1]:
        cur = cur.setdefault(p, {})
    cur[parts[-1]] = value


def build_config_snapshot(search_cfg: Dict[str, Any], paths_to_take: List[str]) -> Dict[str, Any]:
    snapshot = {}
    for path in paths_to_take:
        value = extract_from_path(search_cfg, path)
        if value is not None:
            insert_into_path(snapshot, path, value)
    return snapshot


