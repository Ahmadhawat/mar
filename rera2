4️⃣ Client code for your pipeline

reranker_client.py

import requests


class RerankerClient:

    def __init__(self, url="http://127.0.0.1:8020"):
        self.url = url.rstrip("/")

    def rerank(self, query, candidates, top_k=10):

        payload = {
            "query": query,
            "candidates": candidates,
            "top_k": top_k,
        }

        r = requests.post(
            f"{self.url}/rerank",
            json=payload,
            timeout=300,
        )

        r.raise_for_status()

        return r.json()


